{
  // Visuals
  "editor.tabSize": 2,
  "editor.renderWhitespace": "all",
  "editor.fontFamily": "FiraCode-Retina",
  "editor.fontLigatures": true,
  "workbench.sideBar.location": "right",
  "editor.cursorWidth": 3,
  "editor.rulers": [120],
  // Foramtting
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.autoSave": "afterDelay",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "eslint.alwaysShowStatus": true,
  "prettier.arrowParens": "always",
  "prettier.jsxSingleQuote": true,
  "files.trimFinalNewlines": true,
  "editor.autoIndent": "full",
  // Other
  "git.autofetch": true,
  "workbench.editor.enablePreview": false,
  "git.enableSmartCommit": true,
  "emmet.triggerExpansionOnTab": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "terminal.integrated.scrollback": 10000,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "stories.username": "Maible_comfortable",
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.welcomePage.hiddenCategories": ["Setup", "Beginner"],
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "files.associations": {
    "*.svg": "html"
  },
  "terminal.integrated.defaultProfile.osx": "zsh",
  "editor.inlineSuggest.enabled": true,
  "workbench.colorTheme": "Kanagawa",
  "bracket-pair-colorizer-2.depreciation-notice": false,
  "go.toolsManagement.autoUpdate": true,
  "redhat.telemetry.enabled": true,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "cSpell.userWords": [
    "Åland",
    "Authorisation",
    "authorised",
    "AWSX",
    "Barthélemy",
    "Bouvet",
    "Burkina",
    "Caicos",
    "camelcase",
    "cdktf",
    "codegen",
    "COLOURS",
    "Comores",
    "Côte",
    "Curations",
    "d'Ivoire",
    "DACH",
    "dazn",
    "documentum",
    "Eswatini",
    "Eustatius",
    "eventbridge",
    "Faso",
    "Fastify",
    "firstname",
    "formik",
    "Futuna",
    "getreg",
    "holibob",
    "initialise",
    "initialised",
    "Islas",
    "keymap",
    "Kitts",
    "knexfile",
    "Kysely",
    "lastname",
    "Leste",
    "Localisation",
    "Localisations",
    "Luxembourgish",
    "Maarten",
    "mantine",
    "Marino",
    "Mayen",
    "noremap",
    "nvim",
    "OPENAI",
    "openapi",
    "organisation",
    "Personalise",
    "predev",
    "premint",
    "Príncipe",
    "progressbar",
    "Rica",
    "Rican",
    "ruleset",
    "Scarrott",
    "schemaname",
    "Sénégal",
    "setreg",
    "synchronisation",
    "tablename",
    "tanstack",
    "testid",
    "Tokelau",
    "Tomé",
    "traveller",
    "TRPC",
    "wsrun",
    "Xenomorphs"
  ],
  "github.copilot.enable": {
    "*": true,
    "yaml": true,
    "plaintext": true,
    "markdown": true,
    "typescript": true
  },
  "editor.guides.bracketPairs": true,
  "yaml.schemas": {
    "https://s3.eu-central-1.amazonaws.com/schemas.plat.dazn-dev.com/dazn-manifest/4.0.0.schema.json": ".dazn-manifest.yml"
  },
  "debug.javascript.autoAttachFilter": "disabled",
  "vitest.enable": true,
  "npm.keybindingsChangedWarningShown": true,
  "editor.stickyScroll.enabled": true,
  "[python]": {
    "editor.formatOnType": true
  },
  "githubPullRequests.pullBranch": "never",
  "prisma.showPrismaDataPlatformNotification": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "playwright.reuseBrowser": false,
  "playwright.showTrace": false,
  "playwright.runGlobalSetupOnEachRun": false,
  "typescript.tsserver.log": "off",
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.enableTracing": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "amazonQ.suppressPrompts": {
    "amazonQChatDisclaimer": true
  },
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3"
}
