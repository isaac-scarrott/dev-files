{
  "git_panel": {
    "tree_view": true
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "file_types": {
    "html": ["*.svg"],
  },
  "auto_indent_on_paste": true,
  "show_whitespaces": "all",
  "show_edit_predictions": true,
  "wrap_guides": [120],
  "tab_size": 2,
  "base_keymap": "VSCode",
  "notification_panel": {
    "dock": "left",
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark"
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "FiraCode-Retina",
  "relative_line_numbers": true,
  "cursor_blink": false,
  "scrollbar": {
    "show": "never",
  },
  "terminal": {
    "max_scroll_history_lines": 10000,
  },
  "project_panel": {
    "dock": "right",
  },
  "preview_tabs": {
    "enabled": true,
  },
}
